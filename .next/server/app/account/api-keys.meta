{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/account/layout,_N_T_/account/[path]/layout,_N_T_/account/[path]/page,_N_T_/account/api-keys"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/account/$d$path/__PAGE__",
    "/account/$d$path",
    "/account",
    "/_index",
    "/_head"
  ]
}